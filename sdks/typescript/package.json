{
  "name": "openagentmail",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for OpenAgentMail - Email API for AI Agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "email",
    "api",
    "ai",
    "agents",
    "openagentmail",
    "sdk"
  ],
  "author": "OpenAgentMail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openagentmail/openagentmail-ts"
  },
  "homepage": "https://openagentmail.com",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}